OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
ASSEMBLYAI_API_KEY=...

# Scoring provider preference. The named one is tried first; the others fall
# back if their keys are set. One of: openai | gemini | anthropic.
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-opus-4-7
GEMINI_MODEL=gemini-2.5-flash
TRANSCRIBER=auto
LOCAL_WHISPER_MODEL=small
ASSEMBLYAI_LANGUAGE=hi
EFFORT=high
MAX_CONCURRENCY=4

# Daily email report (Settings page). CRON_SECRET is any random string — the
# external scheduler must pass it as ?key=...
CRON_SECRET=

# Email transport — use EITHER Gmail SMTP (no domain needed) ...
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
# ... OR Resend (needs a verified sender domain):
RESEND_API_KEY=re_...
# Display "from". For Gmail SMTP it should be the SMTP_USER address.
REPORT_FROM_EMAIL=Otis <you@gmail.com>
